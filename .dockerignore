# Git・エディタ関連
/.git
/.gitattributes
/.gitignore
/.vscode
/.claude
/.serena
/.ruby-lsp
.DS_Store

# Docker 関連（イメージには含めない）
/.dockerignore
/Dockerfile*
/compose*.yaml

# 秘密情報（RAILS_MASTER_KEY は実行時に環境変数で渡す）
/backend/config/master.key
/backend/config/credentials/*.key
.env*
/frontend/.env*

# ログ・一時ファイル
/backend/log/*
!/backend/log/.keep
/backend/tmp/*
!/backend/tmp/pids
/backend/tmp/pids/*
!/backend/tmp/pids/.keep

# 開発時にアップロードされたファイル
/backend/storage/*
!/backend/storage/.keep

# 依存パッケージ（イメージ内でインストールする）
/backend/.bundle
/backend/vendor/bundle
/frontend/node_modules

# Vite のビルド成果物（イメージビルド時に再生成する）
/backend/public/index.html
/backend/public/assets

# テスト・ドキュメント
/backend/spec
/docs
/img
/README.md
